Bootstrap: localimage
From: /mnt/guanli/kangkai/RIC/ubuntu_22.04.sif

%labels
    Author ricpipe
    Version v1.2-with-TrimGalore
    Description RIC-seq pipeline with complete Perl modules and Trim Galore

%setup
    # Create directories inside the image
    mkdir -p $SINGULARITY_ROOTFS/RICseq_scripts_root
    mkdir -p $SINGULARITY_ROOTFS/mnt/software

%files
    # 1. Copy RICpipe-master to the image
    /mnt/guanli/kangkai/RIC/RICpipe-master/*  /mnt/RICseq_scripts_root/
    # 2. Copy software to /mnt/software root
    /mnt/guanli/kangkai/RIC/softwares/*  /mnt/software/

%post
    export DEBIAN_FRONTEND=noninteractive
    ln -fs /usr/share/zoneinfo/Asia/Shanghai /etc/localtime

    echo "======================================"
    echo "Step 1: Install Basic Packages"
    echo "======================================"
    apt update
    apt install -y \
        vim wget unzip zip \
        perl \
        build-essential \
        cpanminus \
        zlib1g-dev libssl-dev libffi-dev libbz2-dev \
        libreadline-dev libsqlite3-dev libncurses5-dev \
        liblzma-dev tk-dev uuid-dev \
        openjdk-11-jre-headless \
        python3-pip \
        locales \
        bzip2 \
        liblist-moreutils-perl \
        curl

    dpkg-reconfigure -f noninteractive tzdata

    echo "======================================"
    echo "Step 2: Configure Python Symbolic Link"
    echo "======================================"
    ln -s /usr/bin/python3 /usr/bin/python
    python --version || echo "Python symbolic link created successfully"

    echo "======================================"
    echo "Step 3: Install Perl Modules"
    echo "======================================"
    (echo y; echo o conf prerequisites_policy follow; echo o conf commit) | cpan
    cpanm --notest List::Util File::Spec File::Basename Getopt::Long Cwd Graph::Undirected
    cpanm --notest Statistics::Distributions Math::CDF

    echo "======================================"
    echo "Step 4: Install Bioinformatics Tools"
    echo "======================================"

    # FastQC
    cd /mnt/software
    unzip -o fastqc_v0.12.1.zip
    chmod +x /mnt/software/FastQC/fastqc
    ln -s /mnt/software/FastQC/fastqc /usr/local/bin/fastqc

    # STAR
    cd /mnt/software
    tar -zxvf 2.7.11b.tar.gz
    cd STAR-2.7.11b/source
    make
    ln -s /mnt/software/STAR-2.7.11b/source/STAR /usr/local/bin/STAR

    # SAMtools
    cd /mnt/software
    tar -jxvf samtools-1.22.1.tar.bz2
    cd samtools-1.22.1
    ./configure
    make
    make install

    # BEDtools
    cd /mnt/software
    tar -zxvf bedtools-2.28.0.tar.gz
    cd bedtools2
    make
    ln -s /mnt/software/bedtools2/bin/bedtools /usr/local/bin/bedtools

    # cutadapt & MultiQC
    pip3 install --upgrade pip
    pip3 install cutadapt==3.4 multiqc==1.19

    # Trim Galore
    cd /mnt/software
    wget https://github.com/FelixKrueger/TrimGalore/archive/0.6.10.tar.gz -O trim_galore.tar.gz
    tar xvzf trim_galore.tar.gz
    ln -s /mnt/software/TrimGalore-0.6.10/trim_galore /usr/local/bin/trim_galore

    # Locale
    echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
    locale-gen en_US.UTF-8
    update-locale LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

%environment
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
    export PATH=/usr/local/bin:$PATH
    export PERL5LIB=/usr/local/lib/x86_64-linux-gnu/perl/5.34.0:/usr/local/share/perl/5.34.0:$PERL5LIB

%runscript
    exec /bin/bash "$@"

%test
    fastqc --version
    STAR --version
    samtools --version
    bedtools --version
    cutadapt --version
    trim_galore --version
    multiqc --version
    perl -MMath::CDF -e 'print "Math::CDF: OK\n"'
